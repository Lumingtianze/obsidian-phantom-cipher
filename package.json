{
	"name": "obsidian-phantom-cipher",
	"version": "1.0.0",
	"description": "Transparent vault encryption for Obsidian using Argon2id and AES-GCM.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"plugin",
		"encryption",
		"crypto",
		"security"
	],
	"license": "MPL-2.0",
	"devDependencies": {
		"@types/node": "^25.6.2",
		"@typescript-eslint/eslint-plugin": "8.59.2",
		"@typescript-eslint/parser": "8.59.2",
		"builtin-modules": "5.2.0",
		"esbuild": "0.28.0",
		"eslint": "9.14.0",
		"tslib": "2.8.1",
		"typescript": "6.0.3"
	},
	"dependencies": {
		"obsidian": "latest",
		"hash-wasm": "^4.12.0"
	}
}
