{
	"name": "obsidian-phantom-cipher",
	"version": "1.0.8",
	"description": "Transparent vault encryption for Obsidian using Argon2id and AES-GCM.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"plugin",
		"encryption",
		"crypto",
		"security"
	],
	"license": "MPL-2.0",
	"devDependencies": {
		"@types/node": "^25.8.0",
		"@typescript-eslint/eslint-plugin": "8.59.3",
		"@typescript-eslint/parser": "8.59.3",
		"esbuild": "0.28.0",
		"eslint": "10.4.0",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"jiti": "^2.7.0",
		"tslib": "2.8.1",
		"typescript": "6.0.3",
		"typescript-eslint": "^8.59.3"
	},
	"dependencies": {
		"hash-wasm": "^4.12.0",
		"obsidian": "latest"
	}
}
